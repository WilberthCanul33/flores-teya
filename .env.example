LOCAL_DB_PASSWORD=password_bd_local
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432

# Configuración para DOCKER
DOCKER_DB_NAME=organic_veggies_db
DOCKER_DB_USER=organic_user
DOCKER_DB_PASSWORD=Alberto2320c
