# Control de email
USE_MAILTRAP=False

# Configuración de Email para GMAIL REAL
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-app


# URL base del sitio (importante para enlaces de verificación de email)
# 🔴 CAMBIAR SEGÚN EL ENTORNO:
# - Desarrollo local: http://localhost:8000
# - Producción (localhost): http://localhost  
# - Producción (dominio): https://tudominio.com
SITE_URL=http://localhost:8000


# Mailtrap Configuration (para pruebas de email)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=0e11532946c065
MAILTRAP_PASSWORD=394abc035aee83

# Dominio para producción
DOMAIN=flores.inmerso.io

# PayPal Configuration
PAYPAL_CLIENT_ID=tu-paypal-client-id
PAYPAL_CLIENT_SECRET=tu-paypal-client-secret
